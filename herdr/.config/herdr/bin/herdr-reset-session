#!/usr/bin/env bash
set -euo pipefail

clear
cat <<'EOF'
Exit Herdr and stop the server

This closes Herdr completely by stopping the server. All workspaces, tabs,
panes, and running processes in the default Herdr session will be closed.

Type RESET and press Enter to continue. Anything else cancels.
EOF

printf "\n> "
read -r answer

if [ "$answer" != "RESET" ]; then
  printf "\nCancelled.\n"
  sleep 1
  exit 0
fi

printf "\nStopping Herdr server...\n"
herdr server stop
